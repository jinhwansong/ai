{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "tmp": "^0.2.3",
    "lodash": "^4.17.23",
    "bn.js": "^5.2.3",
    "glob": "^11.0.0",
    "rimraf": "^5.0.10",
    "@isaacs/brace-expansion": "^5.0.0",
